# Base Docker Network Configurations
NSPL4_EDGE_PROXY_NETWORK_NAME=edge_proxy_network
NSPL4_EDGE_PROXY_NETWORK_SUBNET=172.50.0.0/16
NSPL4_TRUST_DIRECTIVES="
  # Cloudflare IPs
  set_real_ip_from 103.21.244.0/22;
  set_real_ip_from 103.22.200.0/22;
  set_real_ip_from 103.31.4.0/22;
  set_real_ip_from 104.16.0.0/13;
  set_real_ip_from 104.24.0.0/14;
  set_real_ip_from 108.162.192.0/18;
  set_real_ip_from 131.0.72.0/22;
  set_real_ip_from 141.101.64.0/18;
  set_real_ip_from 162.158.0.0/15;
  set_real_ip_from 172.64.0.0/13;
  set_real_ip_from 173.245.48.0/20;
  set_real_ip_from 188.114.96.0/20;
  set_real_ip_from 190.93.240.0/20;
  set_real_ip_from 197.234.240.0/22;
  set_real_ip_from 198.41.128.0/17;
  set_real_ip_from 2400:cb00::/32;
  set_real_ip_from 2405:8100::/32;
  set_real_ip_from 2405:b500::/32;
  set_real_ip_from 2606:4700::/32;
  set_real_ip_from 2803:f800::/32;
  set_real_ip_from 2a06:98c0::/29;
  set_real_ip_from 2c0f:f248::/32;
"
# ==========================================
# LAYER 4 (TCP) - Main Traffic (443
# ==========================================

# L4 SNI Mapping (Domain -> Internal Service Alias)
# The leading dot (.) acts as a wildcard for the domain and all subdomains
NSPL4_SNI_MAPPINGS="
  .domain1.com      app_1_gateway:443;
  .domain2.com      app_1_gateway:443;
  domain3.com       app_2_gateway:443;
  api.domain3.com   app_3_gateway:443;
  www.domain3.com   website_server:443;
"

# ==========================================
# LAYER 7 - HTTP (Exceptions on Port 80)
# ==========================================

# Domains that MUST respond on port 80 (separated by space)
NSPL4_HTTP_DOMAINS="mail.domain3.com domain4.com *.domain4.com"

# Domain mapping to the internal DNS Alias of the container (Domain -> Internal Service Alias)
# The leading dot (.) acts as a wildcard for the domain and all subdomains
NSPL4_HTTP_MAPPINGS="
  mail.domain3.com   mail_server:80;
  www.domain4.com    website_server:80;
  .domain5.com       app_5_gateway:80;
"